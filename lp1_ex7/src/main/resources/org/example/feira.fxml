<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:controller="org.example.controller.FeiraController" alignment="TOP_CENTER" prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <AnchorPane prefHeight="100.0" prefWidth="800.0">
            <children>
                <ImageView fitHeight="80.0" fitWidth="80.0" layoutX="20.0" layoutY="20.0" pickOnBounds="true" preserveRatio="true" AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="20.0">
                    <image>
                        <Image url="@barraca-de-comida.png" />
                    </image>
                </ImageView>
                <Label alignment="CENTER" layoutX="100.0" layoutY="35.0" prefWidth="600.0" text="SISTEMA DA FEIRA" textAlignment="CENTER" AnchorPane.leftAnchor="100.0" AnchorPane.rightAnchor="100.0" AnchorPane.topAnchor="35.0">
                    <font>
                        <Font name="Segoe UI Bold" size="40.0" />
                    </font>
                </Label>
            </children>
        </AnchorPane>

        <Region VBox.vgrow="ALWAYS" />

        <HBox alignment="CENTER" spacing="30.0">
            <children>
                <VBox alignment="CENTER" prefHeight="450.0" prefWidth="380.0" spacing="15.0" style="-fx-background-color: #D3D3D3; -fx-background-radius: 15; -fx-border-color: #99ff99; -fx-border-width: 3; -fx-border-radius: 15;">
                    <children>
                        <Label text="BANCA DO FEIRANTE">
                            <font><Font name="Segoe UI Bold" size="22.0" /></font>
                        </Label>
                        <Label fx:id="labelCaixaFeirante" style="-fx-font-weight: bold; -fx-font-size: 20px;" text="Caixa: R$ 0.00" />

                        <VBox spacing="10.0" style="-fx-padding: 10;">
                            <children>
                                <HBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #FFFACD; -fx-border-color: #DAA520; -fx-border-radius: 5; -fx-padding: 8;">
                                    <children>
                                        <Label prefWidth="150.0" text="ALFACE: R$ 2.79" style="-fx-font-weight: bold;" />
                                        <Button onAction="#comprarAlface" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="+" />
                                        <Button onAction="#devolverAlface" style="-fx-background-color: #f44336; -fx-text-fill: white;" text="-" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #FFFACD; -fx-border-color: #DAA520; -fx-border-radius: 5; -fx-padding: 8;">
                                    <children>
                                        <Label prefWidth="150.0" text="TOMATE: R$ 5.50" style="-fx-font-weight: bold;" />
                                        <Button onAction="#comprarTomate" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="+" />
                                        <Button onAction="#devolverTomate" style="-fx-background-color: #f44336; -fx-text-fill: white;" text="-" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #FFFACD; -fx-border-color: #DAA520; -fx-border-radius: 5; -fx-padding: 8;">
                                    <children>
                                        <Label prefWidth="150.0" text="BANANA: R$ 4.20" style="-fx-font-weight: bold;" />
                                        <Button onAction="#comprarBanana" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="+" />
                                        <Button onAction="#devolverBanana" style="-fx-background-color: #f44336; -fx-text-fill: white;" text="-" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <VBox alignment="CENTER" prefHeight="450.0" prefWidth="300.0" spacing="15.0" style="-fx-background-color: #D3D3D3; -fx-background-radius: 15;">
                    <children>
                        <Label text="CLIENTE">
                            <font><Font name="Segoe UI Bold" size="22.0" /></font>
                        </Label>
                        <Label fx:id="labelSaldoCliente" style="-fx-font-weight: bold; -fx-font-size: 20px;" text="Saldo: R$ 200.00" />
                        <Label text="Clique no [+] para comprar e no [-] para retirar da cesta." textAlignment="CENTER" wrapText="true" style="-fx-font-style: italic;" />
                    </children>
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                </VBox>
            </children>
        </HBox>

        <Region VBox.vgrow="ALWAYS" />

        <HBox alignment="BOTTOM_LEFT">
            <children>
                <Button onAction="#voltarDashboard" style="-fx-background-color: #d3d3d3; -fx-text-fill: black; -fx-font-weight: bold;" text="VOLTAR AO MENU">
                    <HBox.margin><Insets bottom="30.0" left="20.0" /></HBox.margin>
                </Button>
            </children>
        </HBox>
    </children>
</VBox>