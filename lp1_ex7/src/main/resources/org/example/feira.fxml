<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.FeiraController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <HBox spacing="20" alignment="CENTER">
        <children>
            <VBox spacing="5">
                <Label text="BARRACA DO FEIRANTE" style="-fx-font-weight: bold;"/>
                <TableView fx:id="tabelaBarraca" prefHeight="300" prefWidth="250">
                    <columns>
                        <TableColumn fx:id="colNomeBarraca" text="Produto" prefWidth="100"/>
                        <TableColumn fx:id="colQtdBarraca" text="Qtd" prefWidth="60"/>
                        <TableColumn fx:id="colPrecoBarraca" text="Preço" prefWidth="80"/>
                    </columns>
                </TableView>
                <Label fx:id="lblCaixaFeirante" text="Caixa: R$ 0,00" />
            </VBox>

            <VBox spacing="10" alignment="CENTER">
                <Label text="Qtd:" />
                <TextField fx:id="txtQuantidade" prefWidth="50" text="1" />
                <Button onAction="#handleComprar" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="COMPRAR" />
                <Button onAction="#handleReporEstoque" text="REPOR" />
                <Label fx:id="lblStatus" text="Status: Aguardando" wrapText="true" maxWidth="100" />
            </VBox>

            <VBox spacing="5">
                <Label text="SACOLA DO CLIENTE" style="-fx-font-weight: bold;"/>
                <TableView fx:id="tabelaSacola" prefHeight="300" prefWidth="280">
                    <columns>
                        <TableColumn fx:id="colNomeSacola" text="Produto" prefWidth="100"/>
                        <TableColumn fx:id="colQtdSacola" text="Qtd" prefWidth="70"/>
                        <TableColumn fx:id="colPrecoSacola" text="Preço" prefWidth="80"/>
                    </columns>
                </TableView>
                <Label fx:id="lblCarteiraCliente" text="Sua Carteira: R$ 100,00" />
            </VBox>
        </children>
    </HBox>

    <Region VBox.vgrow="ALWAYS" />

    <HBox alignment="BOTTOM_LEFT">
        <children>
            <Button onAction="#voltarDashboard"
                    style="-fx-background-color: #d3d3d3; -fx-text-fill: black; -fx-font-weight: bold;"
                    text="VOLTAR AO MENU" />
        </children>
    </HBox>
</VBox>